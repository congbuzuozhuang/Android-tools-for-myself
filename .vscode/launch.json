{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Android",
      "type": "adb",
      "request": "launch",
      "target": "device",
      "app": "${workspaceFolder}/android/app/build/outputs/apk/debug/app-debug.apk"
    },
    {
      "name": "Launch Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "npm dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["npm dev", "Launch Chrome"]
    }
  ]
}